# Never place real secrets here or commit .env to git
# All production values live in Railway Variables dashboard only

RAZORPAY_KEY=rzp_test_...
RAZORPAY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

WHATSAPP_TOKEN=...
WHATSAPP_PHONE_ID=...
WHATSAPP_MODE=sandbox        # sandbox | production

DATABASE_URL=postgresql://...  # Railway Postgres → Variables → DATABASE_PUBLIC_URL

# Debug endpoints token — set this in Railway backend Variables
# Access: GET /debug/bookings?token=<value>  or  Authorization: Bearer <value>
DEBUG_TOKEN=your-secret-token-here
