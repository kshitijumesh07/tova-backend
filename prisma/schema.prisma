generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Host {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  vehicle   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  trips     Trip[]
  payouts   Payout[]
}

model Route {
  id         String  @id @default(cuid())
  fromName   String
  toName     String
  distanceKm Float   @default(18)
  active     Boolean @default(true)
  trips      Trip[]

  @@unique([fromName, toName])
}

model Trip {
  id            String    @id @default(cuid())
  routeId       String
  route         Route     @relation(fields: [routeId], references: [id])
  hostId        String
  host          Host      @relation(fields: [hostId], references: [id])
  departureTime String
  tripDate      DateTime
  totalSeats    Int
  seatsLeft     Int
  priceInr      Int
  status        String    @default("OPEN")
  rideMode      String    @default("MIXED") // "MIXED" | "WOMEN_ONLY"
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model User {
  id                 String    @id @default(uuid())
  phone              String    @unique
  name               String?
  gender             String?
  govtIdType         String?
  govtIdNumber       String?
  govtDepartment     String?
  govtRole           String?   // TEACHER | LECTURER | OFFICER | STAFF | OTHER
  verificationStatus String    @default("UNVERIFIED") // UNVERIFIED | PENDING | APPROVED | SUSPENDED
  verificationNotes  String?
  tags               String[]  @default([])
  createdAt          DateTime  @default(now())
  bookings           Booking[]
}

model Zone {
  id         String   @id @default(cuid())
  name       String
  district   String
  state      String   @default("Telangana")
  isActive   Boolean  @default(false)
  maxDensity Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  label       String
  description String?
  category    String   @default("general")
  updatedAt   DateTime @updatedAt
}

model FuturePossibility {
  id           String   @id @default(cuid())
  phase        Int      @default(1)
  title        String
  description  String?
  status       String   @default("PLANNED") // PLANNED | IN_PROGRESS | DONE | DISABLED
  enabled      Boolean  @default(false)
  notes        String?
  checklist    String   @default("[]")
  dependencies String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Booking {
  id          String    @id @default(uuid())
  orderId     String    @unique
  phone       String
  rideId      String
  tripId      String?
  pickup      String?
  drop        String?
  amount      Int       @default(5000)
  capacity    Int       @default(10)
  status      String    @default("CREATED")
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
  user        User      @relation(fields: [phone], references: [phone])
  payment     Payment?
  trip        Trip?     @relation(fields: [tripId], references: [id])
}

model Payment {
  id                  String    @id @default(uuid())
  razorpayOrderId     String    @unique
  razorpayPaymentId   String?
  razorpayRefundId    String?
  bookingId           String    @unique
  amount              Int
  status              String    @default("PENDING")
  createdAt           DateTime  @default(now())
  refundedAt          DateTime?
  booking             Booking   @relation(fields: [bookingId], references: [id])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  razorpayId  String   @unique        // event.id — idempotency key
  event       String                  // payment.captured, payment.failed, refund.processed …
  orderId     String?
  paymentId   String?
  status      String   @default("PROCESSED") // PROCESSED | FAILED | SKIPPED
  error       String?
  raw         String                  // full JSON for audit
  createdAt   DateTime @default(now())
}

model Payout {
  id          String    @id @default(cuid())
  hostId      String
  host        Host      @relation(fields: [hostId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  amountInr   Int
  riderCount  Int       @default(0)
  tripCount   Int       @default(0)
  status      String    @default("PENDING")
  reference   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  notes       String?
}
